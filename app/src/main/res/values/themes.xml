<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base theme -->
    <style name="Base.Theme.TicTacToe" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <style name="Theme.TicTacToe" parent="Base.Theme.TicTacToe" />

    <!-- Splash - No ActionBar -->
    <style name="Theme.TicTacToe.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/primary_dark</item>
    </style>

    <!-- NoActionBar for Login/Register -->
    <style name="Theme.TicTacToe.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>
</resources>
