<?xml version="1.0" encoding="utf-8"?>
<!-- ConstraintLayout + GridLayout: GameActivity -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Player cards row -->
    <LinearLayout
        android:id="@+id/playerRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Player 1 (X) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPlayer1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E3F2FD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="X"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"/>
                <TextView
                    android:id="@+id/tvPlayer1Name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player 1"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView
                    android:id="@+id/tvScore1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Player 2 (O) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPlayer2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="O"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"/>
                <TextView
                    android:id="@+id/tvPlayer2Name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player 2"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView
                    android:id="@+id/tvScore2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Turn indicator -->
    <TextView
        android:id="@+id/tvTurnInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lượt của X"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/white"
        android:background="@color/primary"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/playerRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Game Board: GridLayout 5x5 -->
    <GridLayout
        android:id="@+id/gameBoard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:rowCount="5"
        android:columnCount="5"
        android:padding="16dp"
        android:useDefaultMargins="false"
        app:layout_constraintTop_toBottomOf="@id/tvTurnInfo"
        app:layout_constraintBottom_toTopOf="@id/tvGameStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1">

        <!-- Row 0 -->
        <Button android:id="@+id/cell0" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell1" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell2" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell3" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell4" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>

        <!-- Row 1 -->
        <Button android:id="@+id/cell5" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell6" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell7" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell8" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell9" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>

        <!-- Row 2 -->
        <Button android:id="@+id/cell10" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell11" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell12" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell13" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell14" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>

        <!-- Row 3 -->
        <Button android:id="@+id/cell15" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell16" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell17" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell18" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell19" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>

        <!-- Row 4 -->
        <Button android:id="@+id/cell20" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell21" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell22" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell23" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>
        <Button android:id="@+id/cell24" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="" android:textSize="28sp" android:textStyle="bold" android:layout_margin="2dp" android:background="@drawable/cell_background" android:padding="0dp"/>

    </GridLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/tvGameStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/actionButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Action buttons -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnRestart"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Chơi Lại"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btnMenu"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Về Menu"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
